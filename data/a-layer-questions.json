{
  "metadata": {
    "product_name": "TalentAI Adaptability Layer (A-Layer)",
    "version": "1.0.8",
    "total_questions": 20,
    "architecture_philosophy": {
      "zh-CN": "A层被定义为'时代界面层'。它不改变个体的生命内核（P/W/M），但决定了个体与AI工具的摩擦系数。它与M层的区别在于：M层侧重于对AI协作的元认知信念，而A层侧重于实际的适配策略、杠杆利用及风险控制。",
      "en-US": "A-Layer is defined as the 'Era Interface'. It doesn't change the individual's core (P/W/M) but determines the friction coefficient between the individual and AI tools. Unlike M-Layer's focus on cognitive beliefs, A-Layer focuses on adaptation strategies, leverage, and risk control."
    },
    "dimensions": [
      { "id": "A1", "name": "AI Perception", "description": { "zh-CN": "AI认知定位：将AI视为工具、对手还是进化器官", "en-US": "AI Perception: Viewing AI as a tool, rival, or evolving organ." }, "max_score": 10.0 },
      { "id": "A2", "name": "Task Allocation", "description": { "zh-CN": "人机分工能力：识别高价值人类任务与高效率AI任务的边界", "en-US": "Task Allocation: Identifying boundaries between human and AI tasks." }, "max_score": 10.0 },
      { "id": "A3", "name": "Amplification Strategy", "description": { "zh-CN": "AI放大策略：利用AI杠杆实现10倍价值跃迁的思维", "en-US": "Amplification Strategy: Thinking about using AI for 10x value leaps." }, "max_score": 10.0 },
      { "id": "A4", "name": "Learning & Transfer", "description": { "zh-CN": "学习与迁移：快速吸收新工具并进行跨领域方法论迁移的能力", "en-US": "Learning & Transfer: Rapid tool adoption and cross-domain methodology transfer." }, "max_score": 10.0 },
      { "id": "A5", "name": "Dependency & Risk", "description": { "zh-CN": "依赖与风险控制：在不失去独立思考能力的前提下与AI深度协作", "en-US": "Dependency & Risk: Deep collaboration without losing independent thinking." }, "max_score": 10.0 }
    ],
    "scoring_formula": {
      "method": "Dimension-based Cumulative Scoring",
      "interpretation": {
        "zh-CN": "分数越高代表AI时代的适应能力越强。低分反映出认知偏差、使用障碍或潜在的退化风险。该分数作为P/W/M总分的乘数系数（0.8 - 1.5x）。",
        "en-US": "Higher scores indicate stronger AI adaptability. Low scores reflect cognitive bias or atrophy risk. This score acts as a multiplier (0.8 - 1.5x) for the P/W/M base."
      }
    },
    "fusion_rules_explanation": {
      "purpose": { "zh-CN": "A层与P×W×M三层交叉验证，识别AI时代下的职业溢价与熔断点。", "en-US": "A-layer cross-validates with P/W/M to identify career premiums and cut-off points." },
      "integration_logic": { "zh-CN": "高AI适配力可弥补T层传统技能的短板；低AI适配力结合高P(神经质)预警技术焦虑症。", "en-US": "High AI adaptability compensates for T-layer gaps; low adaptability with high P(Neuroticism) warns of tech-anxiety." }
    },
    "behavioral_tags_definition": {
      "threat_perception": { "zh-CN": "威胁感知：视AI为竞争者而非盟友", "en-US": "Threat Perception: AI as a rival." },
      "asset_thinking": { "zh-CN": "资产思维：将Prompt/Workflow积累为数字资产", "en-US": "Asset Thinking: Accumulating AI assets." },
      "ai_atrophy": { "zh-CN": "能力退化风险：独立思考或技能正在萎缩", "en-US": "AI Atrophy: Shrinking skills/independence." },
      "proactive_evolution": { "zh-CN": "主动进化：积极重塑个人价值护城河", "en-US": "Proactive Evolution: Reshaping personal moats." }
    }
  },
