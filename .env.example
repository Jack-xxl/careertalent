# 复制为 .env 后填写（勿提交 .env）
WECHAT_APPID=你的AppID
WECHAT_MCHID=你的商户号
WECHAT_SERIAL_NO=证书序列号
WECHAT_API_V3_KEY=APIv3密钥

# Render：整段 PEM 粘贴到一行时，换行写成 \n
# WECHAT_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# WECHAT_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# 可选：自定义公网地址（未设置时，本地默认 http://localhost:端口）
BASE_URL=https://你的域名

# Render 部署时会自动注入，无需手写；有值时启用微信回调验签 + 前端自动轮询
# RENDER_EXTERNAL_URL=https://xxx.onrender.com
